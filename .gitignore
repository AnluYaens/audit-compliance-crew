# ============================================================
# Environment and secrets
# ============================================================
.env
.env.*
!.env.example

# ============================================================
# Python cache / test / coverage artifacts
# ============================================================
__pycache__/
*.py[cod]
*$py.class
.pytest_cache/
.mypy_cache/
.ruff_cache/
.coverage
htmlcov/

# ============================================================
# Virtual environments
# ============================================================
.venv/
venv/
env/

# ============================================================
# Local agent/runtime state
# ============================================================
.agents/
.codex/

# ============================================================
# Compliance datasets
# The tracked JSON/CSV files in data/ are synthetic demo data.
# Do not replace them with real/private client or compliance data.
# Ignore any additional local/private datasets by default.
# ============================================================
data/*.json
data/*.csv

# Tracked synthetic demo datasets required for local demo/test runs.
!data/client_crm.json
!data/internal_holdings.csv
!data/sanctions.json

# Optional sanitized examples may also be committed.
!data/*.example.json
!data/*.example.csv
!data/README.md

# ============================================================
# Generated outputs
# Keep folders with .gitkeep, ignore generated JSON reports.
# ============================================================
output/*
!output/.gitkeep
!output/evidence/
output/evidence/*
!output/evidence/.gitkeep
output/**/*.json

# ============================================================
# Generated memo/report outputs
# Keep folder placeholder, ignore generated memos.
# ============================================================
memos/*
!memos/.gitkeep

# Local generated-output backup folders
output_old/
memos_old/

# ============================================================
# OS/editor noise
# ============================================================
.DS_Store
Thumbs.db
.vscode/
.idea/
